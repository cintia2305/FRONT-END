!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Produtos - CINTIA SOUZA</title>
<style>
    body {
        background-color: #1a1a1a; /* Fundo Preto/Cinza Escuro */
        color: white;
        font-family: 'Arial', sans-serif;
        margin: 0;
        padding: 20px;
        background-image: linear-gradient(#1a1a1a, #000);
    }
    .container {
        max-width: 800px;
        margin: 0 auto;
        border: 2px solid #333;
        padding: 20px;
        background-color: #111;
        box-shadow: 0 0 20px rgba(0,0,0,0.8);
    }
    header {
        text-align: center;
        margin-bottom: 30px;
    }
    h1 {
        color: #fff;
        font-size: 2.5em;
        margin: 0;
        text-transform: uppercase;
        text-shadow: 2px 2px #ff4500;
    }
    .wifi-badge {
        background-color: #fff;
        color: #000;
        padding: 5px 15px;
        border-radius: 15px;
        font-weight: bold;
        display: inline-block;
        margin-top: 10px;
        font-size: 0.9em;
    }
    .section-title {
        background-color: #ff5500; /* Laranja vibrante */
        color: white;
        padding: 10px;
        text-align: center;
        font-weight: bold;
        font-size: 1.5em;
        text-transform: uppercase;
        margin-top: 30px;
        margin-bottom: 15px;
        clip-path: polygon(0% 0%, 100% 0%, 95% 50%, 100% 100%, 0% 100%, 5% 50%); /* Efeito de Faixa */
    }
    .price-tag {
        text-align: center;
        background-color: #fff;
        color: #000;
        font-weight: bold;
        border-radius: 20px;
        padding: 5px 15px;
        display: inline-block;
        margin-bottom: 15px;
        font-size: 1.2em;
    }
    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    @media (max-width: 600px) {
        .grid { grid-template-columns: 1fr; }
    }
    ul {
        list-style: none;
        padding: 0;
    }
    li {
        margin-bottom: 8px;
        border-bottom: 1px dashed #444;
        padding-bottom: 4px;
        display: flex;
        justify-content: space-between;
    }
    .item-name { font-weight: bold; }
    .item-price { color: #ffcc00; font-weight: bold;}
    .obs { font-size: 0.8em; color: #ccc; display: block; margin-top: -5px; }
    footer {
        text-align: center;
        margin-top: 40px;
        font-size: 0.9em;
        color: #aaa;
        border-top: 1px solid #444;
        padding-top: 20px;
    }
</style>
</head>
<body>

<div class="container">
